{
  "name": "cognitive-dissonance",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:browser:watch": "vitest --config vitest.browser.config.ts",
    "test:e2e": "pnpm build && xvfb-run --auto-servernum pnpm exec playwright test",
    "test:e2e:headed": "pnpm build && xvfb-run --auto-servernum pnpm exec playwright test --headed",
    "cap:sync": "pnpm build && cap sync",
    "cap:sync:ios": "pnpm build && cap sync ios",
    "cap:sync:android": "pnpm build && cap sync android",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:run:ios": "pnpm cap:sync:ios && cap run ios",
    "cap:run:android": "pnpm cap:sync:android && cap run android"
  },
  "dependencies": {
    "@babylonjs/core": "^8.53.0",
    "@babylonjs/gui": "^8.53.0",
    "@babylonjs/havok": "^1.3.11",
    "@babylonjs/loaders": "^8.53.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/device": "^8.0.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "gsap": "^3.14.2",
    "miniplex": "^2.0.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reactylon": "^3.5.4",
    "seedrandom": "^3.0.5",
    "tone": "^15.1.22",
    "yuka": "^0.7.8",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.28.6",
    "@biomejs/biome": "2.4.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/seedrandom": "^3.0.8",
    "@types/yuka": "^0.7.4",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "babel-loader": "^10.0.0",
    "babel-plugin-reactylon": "^1.3.1",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
