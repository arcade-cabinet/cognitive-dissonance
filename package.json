{
  "name": "cognitive-dissonance",
  "version": "4.0.0-alpha.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "vite preview --port 3000",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:browser:watch": "vitest --config vitest.browser.config.ts",
    "test:e2e": "pnpm build && node scripts/run-e2e.mjs",
    "test:e2e:headed": "pnpm build && node scripts/run-e2e.mjs --headed",
    "cap:sync": "pnpm build && cap sync",
    "cap:sync:ios": "pnpm build && cap sync ios",
    "cap:sync:android": "pnpm build && cap sync android",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:run:ios": "pnpm cap:sync:ios && cap run ios",
    "cap:run:android": "pnpm cap:sync:android && cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/device": "^8.0.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "gsap": "^3.14.2",
    "koota": "^0.6.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "seedrandom": "^3.0.5",
    "three-stdlib": "^2.36.1",
    "tone": "^15.1.22",
    "yuka": "^0.7.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@capacitor/cli": "^8.3.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/seedrandom": "^3.0.8",
    "@types/three": "^0.183.1",
    "@types/yuka": "^0.7.4",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^29.0.2",
    "postprocessing": "^6.39.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
